# =============================================================================
# JSOMAdvisor environment template
# -----------------------------------------------------------------------------
# 1. Copy this file to `.env` in the project root (backend reads via load_dotenv).
# 2. For the SPA transcript upload, copy the VITE_* lines into `frontend/.env`
#    (Vite only loads env files from `frontend/`).
# Never commit real `.env` or API keys.
# =============================================================================

# --- Neo4j (prerequisite graph / eligibility) ---
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USERNAME=
NEO4J_PASSWORD=

# --- Pinecone (semantic retrieval) ---
PINECONE_API_KEY=
PINECONE_INDEX=

# --- Groq (LLM chat — degree planner, career mentor, skills gap) ---
GROQ_API_KEY=
# Optional model override (default in code: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=1024
# If your provider rejects a separate system message: LLM_FORCE_SYSTEM_IN_USER=1

# --- Optional: CORS (comma-separated origins). Defaults cover localhost dev.
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -----------------------------------------------------------------------------
# Frontend-only — place these in `frontend/.env` (not the project root).
# -----------------------------------------------------------------------------
# Full URL to POST transcript PDF (must match running backend):
# VITE_TRANSCRIPTPARSER_API=http://127.0.0.1:8000/api/parse-transcript
# Dev-only: bypass password gate if implemented (see frontend/src/auth.ts)
# VITE_SKIP_PASSWORD_AUTH=false
